{
  "permissions": {
    "allow": [
      "PowerShell(Move-Item *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(pnpm install *)",
      "Bash(npm *)",
      "Bash(corepack enable *)",
      "WebFetch(domain:angular.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git clone *)",
      "Bash(uv *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "mcp__angular-cli__list_projects",
      "mcp__angular-cli__get_best_practices",
      "PowerShell(\\(Get-Content README-TEST-GUIDE.md | Measure-Object -Line\\).Lines)",
      "Bash(git fetch *)",
      "Bash(bash *)",
      "PowerShell(git clone *)",
      "Bash(pnpm run *)",
      "Bash(pnpm exec *)",
      "mcp__angular-cli__search_documentation"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/session-start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/pre-compact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory memory-compiler python hooks/session-end.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
